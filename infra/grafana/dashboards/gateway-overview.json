{
  "id": null,
  "uid": "gateway-overview",
  "title": "Gateway Overview",
  "tags": ["gateway", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total[1m])) by (status_code)",
          "legendFormat": "status {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Latency p50/p95",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_http_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_http_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Provider Traffic Distribution",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(gateway_provider_requests_total[1m])) by (provider_id)",
          "legendFormat": "{{provider_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Token Throughput",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(gateway_llm_prompt_tokens_total[1m]))",
          "legendFormat": "prompt tokens/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(gateway_llm_completion_tokens_total[1m]))",
          "legendFormat": "completion tokens/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Service CPU Usage",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(gateway_process_cpu_time_seconds[1m])",
          "legendFormat": "gateway cpu seconds/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(process_cpu_seconds_total{job=\"registry\"}[1m]))",
          "legendFormat": "registry cpu seconds/s",
          "refId": "B"
        }
      ]
    }
  ]
}
