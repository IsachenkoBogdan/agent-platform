AUTH_MODE=jwt_only
AUTH_JWT_ISSUE_TOKENS_CSV=issuer-token

JWT_SECRET=dev-jwt-secret-for-local-only
JWT_ISSUER=agent-platform
JWT_AUDIENCE=agent-platform
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_CLOCK_SKEW_SECONDS=30

GATEWAY_SUPPORTED_MODELS_CSV=gpt-4o-mini,deepseek-chat
GATEWAY_REGISTRY_ENABLED=true
GATEWAY_REGISTRY_URL=http://registry:8001
GATEWAY_PROVIDER_EJECTION_SECONDS=30
GUARDRAILS_ENABLED=true

OTEL_ENDPOINT=http://otel-collector:4318/v1/traces
MLFLOW_TRACKING_URI=http://mlflow:5000
